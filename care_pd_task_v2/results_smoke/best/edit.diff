 # ─────────────────────────────────────────────────────────────────────────────
 # SECTION A: ROTATION UTILITIES
 # Inlined from CARE-PD/data/preprocessing/preprocessing_utils.py
 # Reference: Zhou et al. 2019 "On the Continuity of Rotation Representations"
 # ─────────────────────────────────────────────────────────────────────────────
 
 def axis_angle_to_quaternion(aa: torch.Tensor) -> torch.Tensor:
     """Axis-angle (..., 3) → quaternion (..., 4) [w,x,y,z]. Taylor for small angles."""
     angles = torch.norm(aa, p=2, dim=-1, keepdim=True)
     half   = 0.5 * angles
     small  = angles.abs() < 1e-6
     s      = torch.where(small, 0.5 - angles**2 / 48, torch.sin(half) / angles.clamp(1e-8))
     return torch.cat([torch.cos(half), aa * s], dim=-1)
 
 
 def quaternion_to_matrix(q: torch.Tensor) -> torch.Tensor:
     """Quaternion (..., 4) [w,x,y,z] → rotation matrix (..., 3, 3)."""
     r, i, j, k = torch.unbind(q, -1)
     s = 2.0 / (q * q).sum(-1)
     o = torch.stack([
         1-s*(j*j+k*k), s*(i*j-k*r),   s*(i*k+j*r),
         s*(i*j+k*r),   1-s*(i*i+k*k), s*(j*k-i*r),
         s*(i*k-j*r),   s*(j*k+i*r),   1-s*(i*i+j*j),
     ], dim=-1)
     return o.reshape(q.shape[:-1] + (3, 3))
 
 
 def axis_angle_to_matrix(aa: torch.Tensor) -> torch.Tensor:
     """Axis-angle (..., 3) → rotation matrix (..., 3, 3). Stable for all angles."""
     return quaternion_to_matrix(axis_angle_to_quaternion(aa))
 
 
 def matrix_to_rotation_6d(mat: torch.Tensor) -> torch.Tensor:
     """Rotation matrix (..., 3, 3) → 6D representation (..., 6) [first 2 rows].
     WHY 6D: continuous rotation space, no gimbal lock, better gradients."""
     return mat[..., :2, :].clone().reshape(*mat.shape[:-2], 6)
 
 
 def smpl_to_6d(pose: np.ndarray) -> np.ndarray:
     """
     SMPL axis-angle (T, 72) → 6D rotation per frame (T, 144).
     24 joints × 6D = 144 per-frame features.
     """
     T  = len(pose)
     aa = torch.from_numpy(pose.reshape(T, 24, 3)).float()
     r6 = matrix_to_rotation_6d(axis_angle_to_matrix(aa))  # (T, 24, 6)
     return r6.reshape(T, 144).numpy()
 
 
 # ─────────────────────────────────────────────────────────────────────────────
 # SECTION B: PHYSICS-INFORMED FEATURE ENGINEERING
 # ─────────────────────────────────────────────────────────────────────────────
 
 def compute_velocity(rot6d: np.ndarray) -> np.ndarray:
     """
     1st-order temporal diff of 6D features → velocity (T, 144).
     WHY: Bradykinesia (reduced movement speed) is the PRIMARY PD symptom.
     Duplicate first row to keep T identical to rot6d.
     """
     d = np.diff(rot6d, axis=0)
     return np.concatenate([d[:1], d], axis=0)
 
 
 def compute_lr_asymmetry(rot6d: np.ndarray) -> np.ndarray:
     """
     Left-right asymmetry: |rot_left - rot_right| for 9 joint pairs → (T, 54).
     WHY: PD asymmetry (one side more affected) is a primary diagnostic criterion
     and the most discriminative gait feature. SUB01 is a prototypical example.
     """
     j = rot6d.reshape(len(rot6d), 24, 6)
     L = np.array([p[0] for p in LR_PAIRS])
     R = np.array([p[1] for p in LR_PAIRS])
     return np.abs(j[:, L, :] - j[:, R, :]).reshape(len(rot6d), 54)
 
 
 def build_features(pose: np.ndarray) -> np.ndarray:
     """
     Build per-frame feature matrix: 6D_rot(144) + velocity(144) + LR_asym(54) = 342 dims.
     CHANGE v2: Added velocity + asymmetry channels (v1 used 144 only).
     Mutable: add acceleration (2nd diff, 144 more dims), FFT bands, ROM stats.
     """
     rot6d = smpl_to_6d(pose)           # (T, 144)
     vel   = compute_velocity(rot6d)    # (T, 144)
     asym  = compute_lr_asymmetry(rot6d)# (T, 54)
     return np.concatenate([rot6d, vel, asym], axis=1).astype(np.float32)  # (T, 342)
 
 
 def normalize_features(feat_train: list, feat_test: list):
     """
     Z-score normalization using training set statistics.
     CHANGE: Added in v2. This is CRITICAL for neural network convergence.
     Without normalization: 1D-CNN scores 0.23-0.30 (oscillating between classes).
     With normalization: expected 0.45-0.58 (matching or beating RF baseline).
 
     Computes: mean and std from ALL training frames concatenated.
     Applies:  (x - mean) / (std + 1e-6) to both train and test.
     Returns:  normalized train list, normalized test list.
     """
     # WHY: 6D rotation values range ~[-1, +1] but velocity/asym can be tiny (<1e-3).
     #      Without normalization, velocity channels are drowned by rotation channels.
     all_frames = np.concatenate(feat_train, axis=0)  # (N_total_frames, 342)
     mean = all_frames.mean(0)                         # (342,)
     std  = all_frames.std(0)                          # (342,)
 
     def normalize(feats):
         return [(f - mean) / (std + 1e-6) for f in feats]
 
     return normalize(feat_train), normalize(feat_test), mean, std
 
 
 # ─────────────────────────────────────────────────────────────────────────────
 # SECTION C: LOSS FUNCTIONS
 # Inlined from CARE-PD/learning/criterion.py
 # ─────────────────────────────────────────────────────────────────────────────
 
 class WCELoss(nn.Module):
     """
     Weighted Cross-Entropy: per-class weight = N / (n_classes * count_c).
     WHY WCE as default: stable gradient signal even with tiny class-2 count.
     class_weights tensor shape: (n_classes,) on DEVICE.
     """
     def __init__(self, w: torch.Tensor):
         super().__init__()
         self.register_buffer('w', w)
     def forward(self, logits, targets):
         return nn.functional.cross_entropy(logits, targets, weight=self.w)
 
 
 class FocalLoss(nn.Module):
     """
     Focal Loss: alpha*(1-pt)^gamma * CE.  Lin et al. 2017.
     WHY: Down-weights easy class-0 examples, focuses gradient on hard class-2.
     Mutable: alpha=0.25 (global scale), gamma=2.0 (focusing; 0=CE, 5=extreme)
     Try: alpha=0.5, gamma=1.5 for less aggressive focusing.
     """
     def __init__(self, alpha=0.25, gamma=2.0):
         super().__init__()
         self.alpha, self.gamma = alpha, gamma
     def forward(self, logits, targets):
         ce = nn.functional.cross_entropy(logits, targets, reduction='none')
         pt = torch.exp(-ce)
         return (self.alpha * (1-pt)**self.gamma * ce).mean()
 
 
 class LabelSmoothWCE(nn.Module):
     """
     Label smoothing + class weighting combined.
     WHY: UPDRS 0/1/2 are ordinal (adjacent scores are clinically similar).
          Smoothing prevents overconfidence at score boundaries.
     Mutable: smoothing=0.05-0.2.
     """
     def __init__(self, w: torch.Tensor, smoothing=0.1):
         super().__init__()
         self.register_buffer('w', w)
         self.smoothing = smoothing
         self.n = 3
     def forward(self, logits, targets):
         log_p = nn.functional.log_softmax(logits, dim=-1)
         one_hot = torch.zeros_like(log_p).scatter_(1, targets.unsqueeze(1), 1)
         smooth  = (1-self.smoothing)*one_hot + self.smoothing/self.n
         loss    = -(smooth * log_p).sum(-1)
         return (loss * self.w[targets]).mean()
 
 
 def make_weights(y: np.ndarray, n=3) -> torch.Tensor:
     """Inverse-frequency class weights normalized to sum=n."""
     cnt = np.bincount(y, minlength=n).astype(float)
     cnt = np.where(cnt==0, 1.0, cnt)
     return torch.tensor(len(y)/(n*cnt), dtype=torch.float32).to(DEVICE)
 
 
 # ─────────────────────────────────────────────────────────────────────────────
 # SECTION D: OurModel — 1D Temporal CNN (trainable, full sequence)
 #
 # ARCHITECTURE REASONING:
 #   Conv1d chosen over Transformer: 3-5× faster training on 620 samples.
 #   GroupNorm(8): stable with batch_size=8-64 (BatchNorm fails on batch_size=1).
 #   AdaptiveAvgPool: not used; masked mean pool handles variable T correctly.
 #   4 conv blocks with increasing kernel sizes: captures gait at 4 temporal scales.
 #   Dropout(0.4): aggressive regularization for 620-sample dataset.
 #
 # INPUT CHANNELS: 342 = 6D_rot(144) + velocity(144) + LR_asym(54)
 #   After z-score normalization, all channels have ~N(0,1) distribution.
 #
 # PARAMETERS: ~620K  |  GPU MEM: ~40MB batch  |  TIME: ~15-25s/fold RTX A5000
 # ─────────────────────────────────────────────────────────────────────────────
 
 IN_DIM = 342   # mutable: 144 (rot only) / 288 (rot+vel) / 342 (rot+vel+asym)
 
 class OurModel(nn.Module):
     """
     1D temporal CNN for UPDRS classification.
     Input:  (B, T, IN_DIM) padded + lengths mask
     Output: (B, 3) logits
     """
     def __init__(self, in_dim=IN_DIM, hidden=128, n_cls=3, drop=0.35):
         super().__init__()
         H = hidden
         # WHY 4 blocks with k=3,7,15,31:
         #   k=3  → 0.10s window: per-joint tremor / freeze instantaneous
         #   k=7  → 0.23s window: arm swing sub-cycle coordination
         #   k=15 → 0.50s window: stride phase (swing/stance)
         #   k=31 → 1.03s window: full gait cycle (~1 step = ~0.5s PD, ~0.8s normal)
         self.stem = nn.Sequential(
             nn.Conv1d(in_dim, H, 3, padding=1), nn.GroupNorm(8,H), nn.GELU(), nn.Dropout(0.1),
         )
         self.b2 = nn.Sequential(
             nn.Conv1d(H, H, 7,  padding=3), nn.GroupNorm(8,H), nn.GELU(),
         )
         self.b3 = nn.Sequential(
             nn.Conv1d(H, H, 15, padding=7), nn.GroupNorm(8,H), nn.GELU(), nn.Dropout(0.1),
         )
         self.b4 = nn.Sequential(
             nn.Conv1d(H, 64, 31, padding=15), nn.GroupNorm(8,64), nn.GELU(),
         )
         # WHY residual NOT used: 620 train samples → residuals can cause overfitting
         # Mutable: add nn.Conv1d(H,H,1) skip connections for deeper models
         self.head = nn.Sequential(
             nn.Linear(64, 64), nn.GELU(), nn.Dropout(drop), nn.Linear(64, n_cls),
         )
 
     def forward(self, x, lengths=None):
         """x: (B,T,C) → logits: (B,n_cls)"""
         B, T, _ = x.shape
         h = self.stem(x.permute(0,2,1))  # (B,H,T)
         h = self.b2(h)
         h = self.b3(h)
         h = self.b4(h)  # (B,64,T)
         # Masked mean pool: exclude padding frames from average
         if lengths is not None:
             mask = torch.arange(T, device=x.device)[None,:] < lengths[:,None]  # (B,T)
             h = (h * mask.unsqueeze(1)).sum(2) / lengths.float().unsqueeze(1).clamp(1)
         else:
             h = h.mean(2)  # (B,64)
         return self.head(h)
 
 
 class GaitDS(torch.utils.data.Dataset):
     def __init__(self, feats, labels):
         self.X, self.y = feats, labels
     def __len__(self): return len(self.y)
     def __getitem__(self, i): return self.X[i], self.y[i]
 
 
 def collate(batch):
     """Pad variable-length sequences to batch-max T."""
     fs, ls = zip(*batch)
     T = max(f.shape[0] for f in fs)
     C = fs[0].shape[1]
     pad = np.zeros((len(fs), T, C), dtype=np.float32)
     lens = []
     for i, f in enumerate(fs):
         t = f.shape[0]; pad[i,:t] = f; lens.append(t)
     return (torch.from_numpy(pad),
             torch.tensor(ls, dtype=torch.long),
             torch.tensor(lens, dtype=torch.long))
 
 
 def train_cnn_fold(feat_tr, y_tr, feat_te,
                    epochs=80, lr=3e-4, bs=32):
     """
     Train OurModel 1D-CNN for one fold. Returns predictions on test set.
     REQUIRES: feat_tr/feat_te must be z-score normalized (use normalize_features).
     Mutable: epochs, lr, bs, loss_fn, optimizer, scheduler.
     """
     w    = make_weights(y_tr)
     mdl  = OurModel().to(DEVICE)
     n    = sum(p.numel() for p in mdl.parameters() if p.requires_grad)
     print(f'  [CNN] params={n:,}  epochs={epochs}  lr={lr}  bs={bs}  device={DEVICE}')
 
     # WHY WCE: more stable than FocalLoss for class imbalance at this dataset scale
     loss_fn = WCELoss(w)
     opt     = optim.AdamW(mdl.parameters(), lr=lr, weight_decay=1e-4)
     sch     = optim.lr_scheduler.CosineAnnealingLR(opt, T_max=epochs)
 
     bs_eff = min(bs, max(4, len(y_tr)//8))
     loader = torch.utils.data.DataLoader(
         GaitDS(feat_tr, y_tr), batch_size=bs_eff, shuffle=True,
         collate_fn=collate, drop_last=False)
 
     mdl.train()
     for ep in range(epochs):
         for xb, yb, lb in loader:
             xb, yb, lb = xb.to(DEVICE), yb.to(DEVICE), lb.to(DEVICE)
             opt.zero_grad()
             loss_fn(mdl(xb, lb), yb).backward()
             nn.utils.clip_grad_norm_(mdl.parameters(), 1.0)
             opt.step()
         sch.step()
 
     mdl.eval()
     preds = []
     with torch.no_grad():
         test_loader = torch.utils.data.DataLoader(
             GaitDS(feat_te, np.zeros(len(feat_te), dtype=np.int64)),
             batch_size=32, shuffle=False, collate_fn=collate)
         for xb, _, lb in test_loader:
             preds.append(mdl(xb.to(DEVICE), lb.to(DEVICE)).argmax(1).cpu())
     return torch.cat(preds).numpy()
 
 
