 # SECTION F: MotionCLIP SLIDING WINDOW (optional Path C)
 # WHY better than single crop: walks are 210–3015 frames but MotionCLIP needs
 # exactly 60 frames. Single center-crop discards 90%+ of the walk.
 # Sliding window: encode every 60-frame segment every 30 frames, mean-pool
 # all window embeddings → single 512-dim embedding for the full walk.
 # Expected improvement: class2 F1 from 0.047 → 0.30+
 # ─────────────────────────────────────────────────────────────────────────────
 
 def load_motionclip(care_pd_dir: str):
     """
     Load pretrained MotionCLIP encoder (frozen) from checkpoint.
     Returns encoder on DEVICE or None if checkpoint not found.
     Checkpoint: assets/Pretrained_checkpoints/motionclip/motionclip_encoder_checkpoint_0100.pth.tar
     """
     if care_pd_dir is None:
         return None
     ckpt = os.path.join(care_pd_dir, 'assets', 'Pretrained_checkpoints',
                         'motionclip', 'motionclip_encoder_checkpoint_0100.pth.tar')
     if not os.path.isfile(ckpt):
         print(f'  [MotionCLIP] checkpoint not found: {ckpt}')
         return None
     try:
         import collections
         # Build encoder matching checkpoint architecture
         enc = _MotionCLIPEncoder().to(DEVICE)
         ckpt_data = torch.load(ckpt, map_location='cpu', weights_only=False)
         sd = ckpt_data.get('state_dict', ckpt_data)
         msd = enc.state_dict()
         new = collections.OrderedDict()
         for k, v in sd.items():
             k2 = k[7:] if k.startswith('module.') else k
             if k2 in msd: new[k2] = v
         msd.update(new)
         enc.load_state_dict(msd, strict=False)
         enc.eval()
         for p in enc.parameters(): p.requires_grad_(False)
         print(f'  [MotionCLIP] loaded {len(new)}/{len(msd)} layers from checkpoint')
         return enc
     except Exception as e:
         print(f'  [MotionCLIP] load failed: {e}')
         return None
 
 
 class _MotionCLIPEncoder(nn.Module):
     """
     MotionCLIP Transformer VAE encoder. Inlined from CARE-PD model/motionclip/transformer.py.
     Input:  (B, T=60, 25, 6)  [exactly 60 frames, 25 joints, 6D rotation]
     Output: mu token (B, 512)  [distribution mean = deterministic encoding]
     Architecture: Linear embed → positional encoding → 8-layer TransformerEncoder
                   → prepended mu/sigma query tokens → output[0] = mu
     """
     def __init__(self):
         super().__init__()
         D = 512
         self.input_feats = 25 * 6  # 150
         self.embed  = nn.Linear(150, D)
         self.muQ    = nn.Parameter(torch.randn(1, D))
         self.sigQ   = nn.Parameter(torch.randn(1, D))
         # Positional encoding
         pe = torch.zeros(5002, D)
         pos = torch.arange(0, 5002).float().unsqueeze(1)
         div = torch.exp(torch.arange(0, D, 2).float() * (-np.log(10000.0) / D))
         pe[:, 0::2] = torch.sin(pos * div)
         pe[:, 1::2] = torch.cos(pos * div)
         self.register_buffer('pe', pe.unsqueeze(1))
         self.pe_drop = nn.Dropout(0.1)
         layer = nn.TransformerEncoderLayer(D, 4, 1024, 0.1, 'gelu', batch_first=False)
         self.enc = nn.TransformerEncoder(layer, num_layers=8)
 
     def forward(self, x, return_rep=True):
         """x: (B, T, 25, 6) → mu: (B, 512)"""
         B, T, J, F = x.shape
         x = x.permute(1, 0, 2, 3).reshape(T, B, J*F)
         x = self.embed(x)  # (T, B, D)
         y = torch.zeros(B, dtype=torch.long, device=x.device)
         xseq = torch.cat([self.muQ[y].unsqueeze(0), self.sigQ[y].unsqueeze(0), x], 0)
         xseq = self.pe_drop(xseq + self.pe[:T+2])
         out  = self.enc(xseq)
         return out[0]  # mu token: (B, D)
 
 
 def motionclip_sliding_window(enc, pose: np.ndarray,
                                window=60, stride=30) -> np.ndarray:
     """
     Extract MotionCLIP embedding for a variable-length walk via sliding window.
     WHY stride=30 (50% overlap): captures gait events between windows.
     Returns: (512,) mean-pooled embedding across all windows.
     """
     rot6d = smpl_to_6d(pose).reshape(len(pose), 24, 6)  # (T, 24, 6)
     T = len(rot6d)
     # Add zero translation joint: (T, 25, 6)
     full = np.concatenate([rot6d, np.zeros((T, 1, 6), np.float32)], axis=1)
     # Extract windows
     windows = []
     for s in range(0, max(1, T - window + 1), stride):
         seg = full[s:s+window]
         if len(seg) < window:  # pad last short window
             seg = np.concatenate([seg, np.zeros((window-len(seg),25,6),np.float32)])
         windows.append(seg)
     if not windows:
         seg = np.zeros((window, 25, 6), np.float32)
         seg[:min(T,window)] = full[:min(T,window)]
         windows = [seg]
     batch = torch.from_numpy(np.stack(windows)).float().to(DEVICE)  # (W,60,25,6)
     with torch.no_grad():
         embs = enc(batch).cpu().numpy()  # (W, 512)
     return embs.mean(0)  # (512,) — mean-pool all windows
 
 
 def train_motionclip_fold(tr_poses, y_tr, te_poses, care_pd_dir):
     """
     MotionCLIP sliding-window features → LogisticRegression or MLP classifier.
     Falls back to RF if MotionCLIP checkpoint not available.
     EXPECTED SCORE: ~0.45-0.55 (better than single-crop 0.377)
     """
     enc = load_motionclip(care_pd_dir)
     if enc is None:
         print('  [MotionCLIP] fallback to RF')
         return train_rf_fold(tr_poses, y_tr, te_poses)
 
     print(f'  [MotionCLIP] extracting sliding-window embeddings (w={60},s={30})')
     X_tr = np.stack([motionclip_sliding_window(enc, p) for p in tr_poses])  # (N, 512)
     X_te = np.stack([motionclip_sliding_window(enc, p) for p in te_poses])
 
     # WHY LogReg over MLP for small datasets: less overfitting, faster, good calibration
     from sklearn.linear_model import LogisticRegression
     from sklearn.preprocessing import StandardScaler
     sc  = StandardScaler()
     X_tr_sc = sc.fit_transform(X_tr)
     X_te_sc = sc.transform(X_te)
     cnt = np.bincount(y_tr, minlength=3).astype(float)
     cw  = {c: len(y_tr)/(3*max(cnt[c],1)) for c in range(3)}
     clf = LogisticRegression(max_iter=1000, class_weight=cw, C=1.0, random_state=42)
     clf.fit(X_tr_sc, y_tr)
     return clf.predict(X_te_sc)
 
 
