 # SECTION G: ENSEMBLE (optional)
 # Vote across CNN + RF + MotionCLIP predictions.
 # WHY ensemble: each method captures different aspects of PD gait.
 #   CNN: temporal patterns, dynamics
 #   RF: aggregate statistics (mean, variance of rotations)
 #   MotionCLIP: high-level motion semantics from pretraining
 # Mutable: weighted vote (e.g., w=[0.5,0.3,0.2]) instead of majority vote.
 # ─────────────────────────────────────────────────────────────────────────────
 
 def ensemble_vote(*pred_arrays):
     """Majority vote across multiple prediction arrays. Tie → first array wins."""
     stacked = np.stack(pred_arrays, axis=1)  # (N, K)
     from scipy.stats import mode
     return mode(stacked, axis=1, keepdims=False).mode.flatten()
 
 
