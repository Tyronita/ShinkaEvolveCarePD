# Create these at console.runpod.io/user/secrets/
# Then in your pod/endpoint environment variables, map each one:
#
#   ANTHROPIC_API_KEY = {{ RUNPOD_SECRET_ANTHROPIC_API_KEY }}
#   GEMINI_API_KEY    = {{ RUNPOD_SECRET_GEMINI_API_KEY }}
#   HF_TOKEN          = {{ RUNPOD_SECRET_HF_TOKEN }}
#   GITHUB_TOKEN      = {{ RUNPOD_SECRET_GITHUB_TOKEN }}
#
# Set these directly as pod environment variables (not secrets — not sensitive):
#   GITHUB_REPO       = Tyronita/ShinkaEvolveCarePD
#   NUM_GENERATIONS   = 100
#   MAX_EVAL_JOBS     = 4
#   MAX_API_COSTS     = 50.0
#   WEBUI_PORT        = 8080
#   DOCS_PORT         = 8888
#
# Secrets — create at console.runpod.io/user/secrets, map as {{ RUNPOD_SECRET_<NAME> }}
ANTHROPIC_API_KEY=...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=...
HF_TOKEN=...
GITHUB_TOKEN=...
GITHUB_EMAIL=...